  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="200" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="if (context.Bronze_Insert_count > 0) {&#xD;&#xA;    &#xD;&#xA;    // Batch-Konfiguration&#xD;&#xA;    int BATCH_SIZE = 1000;&#xD;&#xA;    int totalRecords = context.Bronze_Insert_count;&#xD;&#xA;    int numberOfBatches = (int)Math.ceil((double)totalRecords / BATCH_SIZE);&#xD;&#xA;    &#xD;&#xA;    // Timestamp für Processed_At&#xD;&#xA;    java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;    String processedAt = sdf.format(new java.util.Date());&#xD;&#xA;    &#xD;&#xA;    // Context-Variablen setzen&#xD;&#xA;    context.Bronze_Insert_Batches = numberOfBatches;&#xD;&#xA;    context.Bronze_Insert_Batch_Size = BATCH_SIZE;&#xD;&#xA;    context.Bronze_Processed_At = processedAt;&#xD;&#xA;    &#xD;&#xA;    System.out.println(&quot;════════════════════════════════════════&quot;);&#xD;&#xA;    System.out.println(&quot;Bronze CDC Insert - Batches: &quot; + numberOfBatches);&#xD;&#xA;    System.out.println(&quot;Anzahl Records: &quot; + totalRecords);&#xD;&#xA;    System.out.println(&quot;════════════════════════════════════════&quot;);&#xD;&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_2"/>
  </node>

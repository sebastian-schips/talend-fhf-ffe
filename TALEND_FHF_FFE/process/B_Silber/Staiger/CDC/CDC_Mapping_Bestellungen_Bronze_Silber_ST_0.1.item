    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.Auf_Nummer = input_row.Auf_Nummer;&#xD;&#xA;output_row.Kun_Nummer = input_row.Kun_Nummer;&#xD;&#xA;output_row.Tur_Nummer = input_row.Tur_Nummer;&#xD;&#xA;output_row.Sto_Nummer = input_row.Sto_Nummer;&#xD;&#xA;output_row.Bea_Nummer = input_row.Bea_Nummer;&#xD;&#xA;output_row.Dau_Nummer = input_row.Dau_Nummer;&#xD;&#xA;output_row.Rec_Nummer = input_row.Rec_Nummer;&#xD;&#xA;output_row.Auf_Liefertag = input_row.Auf_Liefertag;&#xD;&#xA;output_row.Auf_Anlieferzeit_von = input_row.Auf_Anlieferzeit_von;&#xD;&#xA;output_row.Auf_Anlieferzeit_bis = input_row.Auf_Anlieferzeit_bis;&#xD;&#xA;output_row.Auf_Besteller = input_row.Auf_Besteller;&#xD;&#xA;output_row.Auf_Bestellnummer = input_row.Auf_Bestellnummer;&#xD;&#xA;output_row.Auf_Rabatt = input_row.Auf_Rabatt;&#xD;&#xA;output_row.Auf_ohneBerechnung = input_row.Auf_ohneBerechnung;&#xD;&#xA;output_row.Auf_LSNummer = input_row.Auf_LSNummer;&#xD;&#xA;output_row.User_Anlage = input_row.User_Anlage;&#xD;&#xA;output_row.Datum_Anlage = input_row.Datum_Anlage;&#xD;&#xA;output_row.User_Aenderung = input_row.User_Aenderung;&#xD;&#xA;output_row.Datum_Aenderung = input_row.Datum_Aenderung;&#xD;&#xA;output_row.Auf_Belegtext = input_row.Auf_Belegtext;&#xD;&#xA;output_row.Auf_Sammelbeleg = input_row.Auf_Sammelbeleg;&#xD;&#xA;output_row.Auf_KSFreigabe = input_row.Auf_KSFreigabe;&#xD;&#xA;output_row.Vas_Nummer = input_row.Vas_Nummer;&#xD;&#xA;output_row.Bea_Nummer_Komm = input_row.Bea_Nummer_Komm;&#xD;&#xA;output_row.Ahe_Nummer = input_row.Ahe_Nummer;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Update_change_id_list == null || context.Bronze_Update_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Bronze_Update_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Bronze_Update_count = 0;&#xD;&#xA;}&#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA;if (context.Bronze_Update_count == 0) {&#xD;&#xA;    context.Bronze_Update_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Bronze_Update_change_id_list = context.Bronze_Update_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Bronze_Update_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//===== Silver CDC Update SQL aufbauen =====&#xD;&#xA;if (context.Silver_Update_Values == null || context.Silver_Update_Values.equals(&quot;&quot;)) {&#xD;&#xA;context.Silver_Update_Values = &quot;&quot;;&#xD;&#xA;context.Silver_Update_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;String changedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;//Primary Key MIT gr_kuerzel&#xD;&#xA;String primaryKey = context.gr_kuerzel + input_row.Auf_Nummer;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//UPDATE-Zeile&#xD;&#xA;String updateRow = &quot;('Auftrag', 'UPDATE', '&quot; + primaryKey + &quot;', '&quot; + changedAt + &quot;', 0)&quot;;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Update_count == 0) {&#xD;&#xA;context.Silver_Update_Values = updateRow;&#xD;&#xA;} else {&#xD;&#xA;context.Silver_Update_Values = context.Silver_Update_Values + &quot;, &quot; + updateRow;&#xD;&#xA;}&#xD;&#xA;context.Silver_Update_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>

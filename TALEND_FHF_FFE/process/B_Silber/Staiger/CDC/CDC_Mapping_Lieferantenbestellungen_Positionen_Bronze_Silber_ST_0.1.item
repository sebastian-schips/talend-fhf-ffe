    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.Ekp_Nummer = input_row.Ekp_Nummer;&#xD;&#xA;output_row.Ekk_Nummer = input_row.Ekk_Nummer;&#xD;&#xA;output_row.Art_Nummer = input_row.Art_Nummer;&#xD;&#xA;output_row.Ein_Nummer = input_row.Ein_Nummer;&#xD;&#xA;output_row.Ein_Nummer_Kolli = input_row.Ein_Nummer_Kolli;&#xD;&#xA;output_row.Ein_Nummer_Inhalt = input_row.Ein_Nummer_Inhalt;&#xD;&#xA;output_row.Ekp_Kolli = input_row.Ekp_Kolli;&#xD;&#xA;output_row.Ekp_Menge = input_row.Ekp_Menge;&#xD;&#xA;output_row.Ekp_Preiseinheit = input_row.Ekp_Preiseinheit;&#xD;&#xA;output_row.Ekp_Inhalt = input_row.Ekp_Inhalt;&#xD;&#xA;output_row.Ekp_Gewicht = input_row.Ekp_Gewicht;&#xD;&#xA;output_row.Ekp_Preis = input_row.Ekp_Preis;&#xD;&#xA;output_row.Ekp_Rabatt = input_row.Ekp_Rabatt;&#xD;&#xA;output_row.Ekp_Text = input_row.Ekp_Text;&#xD;&#xA;output_row.Sort = input_row.Sort;&#xD;&#xA;output_row.Datum_Anlage = input_row.Datum_Anlage;&#xD;&#xA;output_row.Datum_Aenderung = input_row.Datum_Aenderung;&#xD;&#xA;output_row.Ekp_Charge = input_row.Ekp_Charge;&#xD;&#xA;output_row.Ekp_Vollkontrolle = input_row.Ekp_Vollkontrolle;&#xD;&#xA;output_row.Ekp_Liefertag = input_row.Ekp_Liefertag;&#xD;&#xA;output_row.Rgr_Nummer = input_row.Rgr_Nummer;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Update_change_id_list == null || context.Bronze_Update_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Bronze_Update_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Bronze_Update_count = 0;&#xD;&#xA;}&#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA;if (context.Bronze_Update_count == 0) {&#xD;&#xA;    context.Bronze_Update_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Bronze_Update_change_id_list = context.Bronze_Update_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Bronze_Update_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//===== Silver CDC Update SQL aufbauen =====&#xD;&#xA;if (context.Silver_Update_Values == null || context.Silver_Update_Values.equals(&quot;&quot;)) {&#xD;&#xA;context.Silver_Update_Values = &quot;&quot;;&#xD;&#xA;context.Silver_Update_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;String changedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;//Primary Key MIT gr_kuerzel&#xD;&#xA;String primaryKey = context.gr_kuerzel +input_row.Ekp_Nummer;&#xD;&#xA;&#xD;&#xA;//UPDATE-Zeile&#xD;&#xA;String updateRow = &quot;('EKPosition', 'UPDATE', '&quot; + primaryKey + &quot;', '&quot; + changedAt + &quot;', 0)&quot;;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Update_count == 0) {&#xD;&#xA;context.Silver_Update_Values = updateRow;&#xD;&#xA;} else {&#xD;&#xA;context.Silver_Update_Values = context.Silver_Update_Values + &quot;, &quot; + updateRow;&#xD;&#xA;}&#xD;&#xA;context.Silver_Update_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>

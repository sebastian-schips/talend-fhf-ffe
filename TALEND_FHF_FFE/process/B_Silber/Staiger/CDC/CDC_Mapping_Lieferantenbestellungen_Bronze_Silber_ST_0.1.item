    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.Ekk_Nummer = input_row.Ekk_Nummer;&#xD;&#xA;output_row.Sto_Nummer = input_row.Sto_Nummer;&#xD;&#xA;output_row.Bea_Nummer = input_row.Bea_Nummer;&#xD;&#xA;output_row.Lie_Nummer = input_row.Lie_Nummer;&#xD;&#xA;output_row.Ekb_Nummer = input_row.Ekb_Nummer;&#xD;&#xA;output_row.Ekk_Liefertag = input_row.Ekk_Liefertag;&#xD;&#xA;output_row.Ekk_Rabatt = input_row.Ekk_Rabatt;&#xD;&#xA;output_row.Ekk_Belegnummer = input_row.Ekk_Belegnummer;&#xD;&#xA;output_row.User_Anlage = input_row.User_Anlage;&#xD;&#xA;output_row.Datum_Anlage = input_row.Datum_Anlage;&#xD;&#xA;output_row.User_Aenderung = input_row.User_Aenderung;&#xD;&#xA;output_row.Datum_Aenderung = input_row.Datum_Aenderung;&#xD;&#xA;output_row.Ekk_Uhrzeit = input_row.Ekk_Uhrzeit;&#xD;&#xA;output_row.Ekk_LKW = input_row.Ekk_LKW;&#xD;&#xA;output_row.Ekk_Kommentar = input_row.Ekk_Kommentar;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Insert_change_id_list == null || context.Bronze_Insert_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Bronze_Insert_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Bronze_Insert_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Insert_count == 0) {&#xD;&#xA;    context.Bronze_Insert_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Bronze_Insert_change_id_list = context.Bronze_Insert_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Bronze_Insert_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//===== Silver CDC Insert SQL aufbauen =====&#xD;&#xA;if (context.Silver_Insert_Values == null || context.Silver_Insert_Values.equals(&quot;&quot;)) {&#xD;&#xA;context.Silver_Insert_Values = &quot;&quot;;&#xD;&#xA;context.Silver_Insert_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;String changedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;//Primary Key MIT gr_kuerzel&#xD;&#xA;String primaryKey = context.gr_kuerzel +input_row.Ekk_Nummer;&#xD;&#xA;//INSERT-Zeile&#xD;&#xA;String insertRow = &quot;('EKKopf', 'INSERT', '&quot; + primaryKey + &quot;', '&quot; + changedAt + &quot;', 0)&quot;;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Insert_count == 0) {&#xD;&#xA;context.Silver_Insert_Values = insertRow;&#xD;&#xA;} else {&#xD;&#xA;context.Silver_Insert_Values = context.Silver_Insert_Values + &quot;, &quot; + insertRow;&#xD;&#xA;}&#xD;&#xA;context.Silver_Insert_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;"/>

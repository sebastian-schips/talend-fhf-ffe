0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;String changedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;//Primary Key MIT gr_kuerzel&#xD;&#xA;String primaryKey = context.gr_kuerzel +input_row.Ekk_Nummer;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//UPDATE-Zeile&#xD;&#xA;String updateRow = &quot;('EKKopf', 'UPDATE', '&quot; + primaryKey + &quot;', '&quot; + changedAt + &quot;', 0)&quot;;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Update_count == 0) {&#xD;&#xA;context.Silver_Update_Values = updateRow;&#xD;&#xA;} else {&#xD;&#xA;context.Silver_Update_Values = context.Silver_Update_Values + &quot;, &quot; + updateRow;&#xD;&#xA;}&#xD;&#xA;context.Silver_Update_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;"/>

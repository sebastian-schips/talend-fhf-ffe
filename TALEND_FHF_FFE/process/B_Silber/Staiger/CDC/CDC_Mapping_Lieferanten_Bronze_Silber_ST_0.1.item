  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="720" posY="840">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_2" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_LieferantenID = input_row.GR_LieferantenID;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;output_row.Primary_Key_Value = input_row.Primary_Key_Value;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Delete_change_id_list == null || context.Bronze_Delete_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Bronze_Delete_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Bronze_Delete_count = 0;&#xD;&#xA;}&#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA;if (context.Bronze_Delete_count == 0) {&#xD;&#xA;    context.Bronze_Delete_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Bronze_Delete_change_id_list = context.Bronze_Delete_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Bronze_Delete_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//===== Silver CDC Delete SQL aufbauen =====&#xD;&#xA;if (context.Silver_Delete_Values == null || context.Silver_Delete_Values.equals(&quot;&quot;)) {&#xD;&#xA;context.Silver_Delete_Values = &quot;&quot;;&#xD;&#xA;context.Silver_Delete_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;String changedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;//Primary Key - kommt bereits MIT gr_kuerzel aus Bronze&#xD;&#xA;String primaryKey = input_row.Primary_Key_Value;&#xD;&#xA;&#xD;&#xA;//DELETE-Zeile&#xD;&#xA;String deleteRow = &quot;('Liferanten', 'DELETE', '&quot; + primaryKey + &quot;', '&quot; + changedAt + &quot;', 0)&quot;;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Delete_count == 0) {&#xD;&#xA;context.Silver_Delete_Values = deleteRow;&#xD;&#xA;} else {&#xD;&#xA;context.Silver_Delete_Values = context.Silver_Delete_Values + &quot;, &quot; + deleteRow;&#xD;&#xA;}&#xD;&#xA;context.Silver_Delete_count++;&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_2">

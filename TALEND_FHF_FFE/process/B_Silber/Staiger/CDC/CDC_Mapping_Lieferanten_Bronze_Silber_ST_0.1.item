ut_row.Lie_keineABV;&#xD;&#xA;output_row.Zak_Nummer = input_row.Zak_Nummer;&#xD;&#xA;output_row.Kun_Nummer = input_row.Kun_Nummer;&#xD;&#xA;output_row.Lie_IBAN = input_row.Lie_IBAN;&#xD;&#xA;output_row.Lie_BIC = input_row.Lie_BIC;&#xD;&#xA;output_row.Lie_Preiseinheit = input_row.Lie_Preiseinheit;&#xD;&#xA;output_row.Lie_Kommissionslieferant = input_row.Lie_Kommissionslieferant;&#xD;&#xA;output_row.Pgr_Nummer = input_row.Pgr_Nummer;&#xD;&#xA;output_row.Lie_Fibu = input_row.Lie_Fibu;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Insert_change_id_list == null || context.Bronze_Insert_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Bronze_Insert_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Bronze_Insert_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA;&#xD;&#xA;if (context.Bronze_Insert_count == 0) {&#xD;&#xA;    context.Bronze_Insert_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Bronze_Insert_change_id_list = context.Bronze_Insert_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Bronze_Insert_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//===== Silver CDC Insert SQL aufbauen =====&#xD;&#xA;if (context.Silver_Insert_Values == null || context.Silver_Insert_Values.equals(&quot;&quot;)) {&#xD;&#xA;context.Silver_Insert_Values = &quot;&quot;;&#xD;&#xA;context.Silver_Insert_count = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;String changedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;//Primary Key MIT gr_kuerzel&#xD;&#xA;String primaryKey = context.gr_kuerzel + input_row.Lie_Nummer;&#xD;&#xA;&#xD;&#xA;//INSERT-Zeile&#xD;&#xA;String insertRow = &quot;('Liferanten', 'INSERT', '&quot; + primaryKey + &quot;', '&quot; + changedAt + &quot;', 0)&quot;;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Insert_count == 0) {&#xD;&#xA;context.Silver_Insert_Values = insertRow;&#xD;&#xA;} else {&#xD;&#xA;context.Silver_Insert_Values = context.Silver_Insert_Values + &quot;, &quot; + insertRow;&#xD;&#xA;}&#xD;&#xA;context.Silver_Insert_count++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;"/>

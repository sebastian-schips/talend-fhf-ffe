    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Change_ID, &quot; +&#xD;&#xA;&quot;       \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Table_Name, &quot; +&#xD;&#xA;&quot;       \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Operation_Type, &quot; +&#xD;&#xA;&quot;       \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Primary_Key_Value, &quot; +&#xD;&#xA;&quot;       \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Changed_At, &quot; +&#xD;&#xA;&quot;       \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Processed, &quot; +&#xD;&#xA;&quot;       \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Bronze_Processed_At &quot; +&#xD;&#xA;&quot;FROM   \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze &quot; +&#xD;&#xA;&quot;WHERE  \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Processed = 0 &quot; +&#xD;&#xA;&quot;  AND  \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Table_Name = 'Artikel' &quot; +&#xD;&#xA;&quot;  AND  \&quot;&quot;+context.GR_Master_Schema+&quot;\&quot;.CDC_Changes_Bronze.Operation_Type = 'INSERT' &quot;"/>

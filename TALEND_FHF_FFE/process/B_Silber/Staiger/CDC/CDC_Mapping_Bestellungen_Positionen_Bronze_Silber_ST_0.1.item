    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT  &quot; +&#xD;&#xA;&quot;    pos.Aup_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Auf_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Art_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Pra_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Ein_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Ein_Nummer_Kolli, &quot; +&#xD;&#xA;&quot;    pos.Ein_Nummer_Inhalt, &quot; +&#xD;&#xA;&quot;    pos.Aup_Kolli, &quot; +&#xD;&#xA;&quot;    pos.Aup_Menge, &quot; +&#xD;&#xA;&quot;    pos.Aup_Preiseinheit, &quot; +&#xD;&#xA;&quot;    pos.Aup_Inhalt, &quot; +&#xD;&#xA;&quot;    pos.Aup_Gewicht, &quot; +&#xD;&#xA;&quot;    pos.Aup_Preis, &quot; +&#xD;&#xA;&quot;    pos.Aup_Rabatt, &quot; +&#xD;&#xA;&quot;    pos.Aup_Text, &quot; +&#xD;&#xA;&quot;    pos.Sort, &quot; +&#xD;&#xA;&quot;    pos.Datum_Anlage, &quot; +&#xD;&#xA;&quot;    pos.Datum_Aenderung, &quot; +&#xD;&#xA;&quot;    pos.Rgr_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Aup_Nachladen, &quot; +&#xD;&#xA;&quot;    pos.Aup_Liefertag, &quot; +&#xD;&#xA;&quot;    pos.Ekk_Nummer, &quot; +&#xD;&#xA;&quot;    pos.Aup_Text_intern, &quot; +&#xD;&#xA;&quot;    pos.Aup_Sonderverkauf, &quot; +&#xD;&#xA;&quot;    pos.Aup_nach_TA, &quot; +&#xD;&#xA;&quot;    pos.Aup_Kommission, &quot; +&#xD;&#xA;&quot;    pos.Aup_Fehlt, &quot; +&#xD;&#xA;&quot;    ISNULL(vkp.Vkp_Preis, 0) AS EK_Preis &quot; +&#xD;&#xA;&quot;FROM \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.Staiger_AuftragPositionen pos&quot; +&quot; WITH (NOLOCK) &quot; +&#xD;&#xA;&quot;OUTER APPLY ( &quot; +&#xD;&#xA;&quot;    SELECT TOP 1 vkp.Vkp_Preis &quot; +&#xD;&#xA;&quot;    FROM \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.Staiger_Verkaufspreis vkp &quot; +&#xD;&#xA;&quot;    WHERE vkp.Art_Nummer = pos.Art_Nummer &quot; +&#xD;&#xA;&quot;      AND vkp.Vkp_abDatum &lt;= pos.Aup_Liefertag &quot; +&#xD;&#xA;&quot;    ORDER BY vkp.Vkp_abDatum DESC &quot; +&#xD;&#xA;&quot;) vkp &quot;"/>

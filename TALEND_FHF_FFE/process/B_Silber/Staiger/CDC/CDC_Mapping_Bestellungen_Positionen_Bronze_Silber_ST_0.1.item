  <node componentName="tMSSqlRow" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="2280" posY="1480">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_1" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="false"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="PROPERTY:PROPERTY_TYPE" value="REPOSITORY"/>
    <elementParameter field="TECHNICAL" name="PROPERTY:REPOSITORY_PROPERTY_TYPE" value="_dm714GvIEfCaypKZ6raWlg" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DRIVER" value="MSSQL_PROP"/>
    <elementParameter field="TEXT" name="HOST" value="context.GR_Master_Server"/>
    <elementParameter field="TEXT" name="PORT" value="context.GR_Master_Port"/>
    <elementParameter field="TEXT" name="DB_SCHEMA" value="context.GR_Master_Schema"/>
    <elementParameter field="TEXT" name="DBNAME" value="context.GR_Master_Database"/>
    <elementParameter field="TEXT" name="TYPE" value="MSSQL" show="false"/>
    <elementParameter field="TEXT" name="USER" value="context.GR_Master_Login"/>
    <elementParameter field="PASSWORD" name="PASS" value="context.GR_Master_Password"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="CHECK" name="IDENTITY_INSERT" value="false"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;MERGE INTO \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;&quot; + context.DB_Ziel + &quot;\&quot; tgt &quot; +&#xD;&#xA;&quot;USING ( &quot; +&#xD;&#xA;&quot;   SELECT &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;GR_BestellID\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;GR_PositionsID\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;PositionsID\&quot; AS BIGINT) AS \&quot;PositionsID\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;GR_Betrieb\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Bestellnummer\&quot; AS BIGINT) AS \&quot;Bestellnummer\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Artikelnummer\&quot; AS BIGINT) AS \&quot;Artikelnummer\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Artikelbezeichnung\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Menge\&quot; AS FLOAT) AS \&quot;Menge\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Kolli\&quot; AS FLOAT) AS \&quot;Kolli\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Inhalt\&quot; AS FLOAT) AS \&quot;Inhalt\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Gewicht\&quot; AS FLOAT) AS \&quot;Gewicht\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Preis\&quot; AS FLOAT) AS \&quot;Preis\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Bestelleinheit\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;PreisSummePosition\&quot; AS FLOAT) AS \&quot;PreisSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Preiseinheit\&quot; AS BIGINT) AS \&quot;Preiseinheit\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Rabatt\&quot; AS FLOAT) AS \&quot;Rabatt\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;GewichtSummePosition\&quot; AS FLOAT) AS \&quot;GewichtSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Warenwert_netto\&quot; AS DECIMAL(30,4)) AS \&quot;Warenwert_netto\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Warenwert_brutto\&quot; AS DECIMAL(30,4)) AS \&quot;Warenwert_brutto\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Steuersatz\&quot; AS DECIMAL(30,4)) AS \&quot;Steuersatz\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATE, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Lieferdatum_Position\&quot;, 105) AS \&quot;Lieferdatum_Position\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Bemerkung\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Sortierung\&quot; AS BIGINT) AS \&quot;Sortierung\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;EK_Preis\&quot; AS FLOAT) AS \&quot;EK_Preis\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;EK_Preiseinheit\&quot; AS BIGINT) AS \&quot;EK_Preiseinheit\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;EK_PreisSummePosition\&quot; AS FLOAT) AS \&quot;EK_PreisSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Marge\&quot; AS FLOAT) AS \&quot;Marge\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;MargeSummePosition\&quot; AS FLOAT) AS \&quot;MargeSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;       CASE WHEN LOWER(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Leergut\&quot;) = 'true' THEN 1 ELSE 0 END AS \&quot;Leergut\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATETIME, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Letzte_Aenderung\&quot;, 120) AS \&quot;Letzte_Aenderung\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATETIME, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Erstellt_Am\&quot;, 120) AS \&quot;Erstellt_Am\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Gruppe\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Artikelfamilie\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Unterwarengruppe\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Hauptwarengruppe\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Rechnungsnummer\&quot; AS INT) AS \&quot;Rechnungsnummer\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATE, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Rechnungsdatum\&quot;, 105) AS \&quot;Rechnungsdatum\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot;.\&quot;Land\&quot; &quot; +&#xD;&#xA;&quot;   FROM \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Update_&quot; + context.kurzel + &quot;_Kundenbestellungen_Positionen\&quot; &quot; +&#xD;&#xA;&quot;   WHERE \&quot;GR_PositionsID\&quot; IS NOT NULL &quot; +&#xD;&#xA;&quot;     AND \&quot;GR_PositionsID\&quot; &lt;> '' &quot; +&#xD;&#xA;&quot;) src &quot; +&#xD;&#xA;&quot;ON tgt.\&quot;GR_PositionsID\&quot; = src.\&quot;GR_PositionsID\&quot; &quot; +&#xD;&#xA;&quot;WHEN MATCHED THEN UPDATE SET &quot; +&#xD;&#xA;&quot;   tgt.\&quot;GR_BestellID\&quot; = src.\&quot;GR_BestellID\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;PositionsID\&quot; = src.\&quot;PositionsID\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;GR_Betrieb\&quot; = src.\&quot;GR_Betrieb\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Bestellnummer\&quot; = src.\&quot;Bestellnummer\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Artikelnummer\&quot; = src.\&quot;Artikelnummer\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Artikelbezeichnung\&quot; = src.\&quot;Artikelbezeichnung\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Menge\&quot; = src.\&quot;Menge\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Kolli\&quot; = src.\&quot;Kolli\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Inhalt\&quot; = src.\&quot;Inhalt\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Gewicht\&quot; = src.\&quot;Gewicht\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Preis\&quot; = src.\&quot;Preis\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Bestelleinheit\&quot; = src.\&quot;Bestelleinheit\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;PreisSummePosition\&quot; = src.\&quot;PreisSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Preiseinheit\&quot; = src.\&quot;Preiseinheit\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Rabatt\&quot; = src.\&quot;Rabatt\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;GewichtSummePosition\&quot; = src.\&quot;GewichtSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Warenwert_netto\&quot; = src.\&quot;Warenwert_netto\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Warenwert_brutto\&quot; = src.\&quot;Warenwert_brutto\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Steuersatz\&quot; = src.\&quot;Steuersatz\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Lieferdatum_Position\&quot; = src.\&quot;Lieferdatum_Position\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Bemerkung\&quot; = src.\&quot;Bemerkung\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Sortierung\&quot; = src.\&quot;Sortierung\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;EK_Preis\&quot; = src.\&quot;EK_Preis\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;EK_Preiseinheit\&quot; = src.\&quot;EK_Preiseinheit\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;EK_PreisSummePosition\&quot; = src.\&quot;EK_PreisSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Marge\&quot; = src.\&quot;Marge\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;MargeSummePosition\&quot; = src.\&quot;MargeSummePosition\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Leergut\&quot; = src.\&quot;Leergut\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Letzte_Aenderung\&quot; = src.\&quot;Letzte_Aenderung\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Erstellt_Am\&quot; = src.\&quot;Erstellt_Am\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Gruppe\&quot; = src.\&quot;Gruppe\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Artikelfamilie\&quot; = src.\&quot;Artikelfamilie\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Unterwarengruppe\&quot; = src.\&quot;Unterwarengruppe\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Hauptwarengruppe\&quot; = src.\&quot;Hauptwarengruppe\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Rechnungsnummer\&quot; = src.\&quot;Rechnungsnummer\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Rechnungsdatum\&quot; = src.\&quot;Rechnungsdatum\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Land\&quot; = src.\&quot;Land\&quot;;&quot;&#xD;&#xA;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>

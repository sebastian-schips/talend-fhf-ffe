  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="640" posY="1640">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_7" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="&#xD;&#xA;&#xD;&#xA;if (context.Silver_Delete_count > 0) {&#xD;&#xA;    &#xD;&#xA;    // Batch-Konfiguration&#xD;&#xA;    int BATCH_SIZE = 1000;&#xD;&#xA;    int totalRecords = context.Silver_Delete_count;&#xD;&#xA;    int numberOfBatches = (int)Math.ceil((double)totalRecords / BATCH_SIZE);&#xD;&#xA;    &#xD;&#xA;    // Context-Variablen für tLoop setzen&#xD;&#xA;    context.Silver_Delete_Batches = numberOfBatches;&#xD;&#xA;    context.Silver_Delete_Batch_Size = BATCH_SIZE;&#xD;&#xA;    &#xD;&#xA;    System.out.println(&quot;════════════════════════════════════════&quot;);&#xD;&#xA;    System.out.println(&quot;Silver CDC Delete - Batches: &quot; + numberOfBatches);&#xD;&#xA;    System.out.println(&quot;Anzahl Silver CDC Delete Records: &quot; + totalRecords);&#xD;&#xA;    System.out.println(&quot;Batch Size: &quot; + BATCH_SIZE);&#xD;&#xA;    System.out.println(&quot;════════════════════════════════════════&quot;);&#xD;&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_7"/>
  </node>

    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_LieferBestellID = input_row.GR_LieferBestellID;&#xD;&#xA;output_row.GR_Betrieb = input_row.GR_Betrieb;&#xD;&#xA;output_row.GR_PositionsID = input_row.GR_PositionsID;&#xD;&#xA;output_row.PositionsID = input_row.PositionsID;&#xD;&#xA;output_row.GR_Artikelnummer = input_row.GR_Artikelnummer;&#xD;&#xA;output_row.Artikelnummer = input_row.Artikelnummer;&#xD;&#xA;output_row.Artikelbezeichnung = input_row.Artikelbezeichnung;&#xD;&#xA;output_row.Inhalt = input_row.Inhalt;&#xD;&#xA;output_row.Gewicht = input_row.Gewicht;&#xD;&#xA;output_row.Kolli = input_row.Kolli;&#xD;&#xA;output_row.Menge = input_row.Menge;&#xD;&#xA;output_row.Preiseinheit = input_row.Preiseinheit;&#xD;&#xA;output_row.Preis = input_row.Preis;&#xD;&#xA;output_row.Bestelleinheit = input_row.Bestelleinheit;&#xD;&#xA;output_row.Verkaufseinheit = input_row.Verkaufseinheit;&#xD;&#xA;output_row.GewichtSummePosition = input_row.GewichtSummePosition;&#xD;&#xA;output_row.PreisSummePosition = input_row.PreisSummePosition;&#xD;&#xA;output_row.PreisProKG = input_row.PreisProKG;&#xD;&#xA;output_row.Warenwert = input_row.Warenwert;&#xD;&#xA;output_row.Warenwert_rabattiert = input_row.Warenwert_rabattiert;&#xD;&#xA;output_row.Warenwert_rabattiert_brutto = input_row.Warenwert_rabattiert_brutto;&#xD;&#xA;output_row.Rabatt_Prozent = input_row.Rabatt_Prozent;&#xD;&#xA;output_row.Rabatt_EUR = input_row.Rabatt_EUR;&#xD;&#xA;output_row.Rueckverguetung_Prozent = input_row.Rueckverguetung_Prozent;&#xD;&#xA;output_row.Rueckverguetung_EUR = input_row.Rueckverguetung_EUR;&#xD;&#xA;output_row.Partieposition = input_row.Partieposition;&#xD;&#xA;output_row.Land = input_row.Land;&#xD;&#xA;output_row.Retourgrund = input_row.Retourgrund;&#xD;&#xA;output_row.Gruppe = input_row.Gruppe;&#xD;&#xA;output_row.Artikelfamilie = input_row.Artikelfamilie;&#xD;&#xA;output_row.Unterwarengruppe = input_row.Unterwarengruppe;&#xD;&#xA;output_row.Hauptwarengruppe = input_row.Hauptwarengruppe;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//==== PARSING ====&#xD;&#xA;ArtikelParser.ArtikelParseResult r = ArtikelParser.parse(&#xD;&#xA;input_row.Artikelbezeichnung,&#xD;&#xA;input_row.Unterwarengruppe,&#xD;&#xA;input_row.Artikelfamilie,&#xD;&#xA;input_row.GR_Betrieb,&#xD;&#xA;String.valueOf(input_row.Artikelnummer),&#xD;&#xA;globalMap&#xD;&#xA;);&#xD;&#xA;&#xD;&#xA;//==== ERGEBNISSE ZUWEISEN ====&#xD;&#xA;output_row.parsed_art                    = r.art;&#xD;&#xA;output_row.parsed_sorte                  = r.sorte;&#xD;&#xA;output_row.parsed_merkmale               = r.merkmale;&#xD;&#xA;output_row.parsed_schnittart             = r.schnittart;&#xD;&#xA;output_row.parsed_schnittgroesse         = r.schnittgroesse;&#xD;&#xA;output_row.parsed_farbe                  = r.farbe;&#xD;&#xA;output_row.parsed_land                   = r.land;&#xD;&#xA;output_row.parsed_bio                    = r.bio;&#xD;&#xA;output_row.parsed_siegel                 = r.siegel;&#xD;&#xA;output_row.parsed_mhd                    = r.mhd;&#xD;&#xA;output_row.parsed_zustand                = r.zustand;&#xD;&#xA;output_row.parsed_verband                = r.verband;&#xD;&#xA;output_row.parsed_prozent                = r.prozent;&#xD;&#xA;output_row.parsed_kaliber                = r.kaliber;&#xD;&#xA;output_row.parsed_gewicht                = r.gewicht;&#xD;&#xA;output_row.parsed_stueck                 = r.stueck;&#xD;&#xA;output_row.parsed_satz                   = r.satz;&#xD;&#xA;output_row.parsed_laenge                 = r.laenge;&#xD;&#xA;output_row.parsed_rest                   = r.rest;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="import java.util.Set;&#xA;import java.util.HashSet;&#xA;import java.util.Map;&#xA;import java.util.HashMap;&#xA;import routines.tmp_parser;"/>

rwarengruppe;&#xD;&#xA;output_row.Hauptwarengruppe = input_row.Hauptwarengruppe;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//==== PARSING ====&#xD;&#xA;ArtikelParser.ArtikelParseResult r = ArtikelParser.parse(&#xD;&#xA;input_row.Artikelbezeichnung,&#xD;&#xA;input_row.Unterwarengruppe,&#xD;&#xA;input_row.Artikelfamilie,&#xD;&#xA;input_row.GR_Betrieb,&#xD;&#xA;String.valueOf(input_row.Artikelnummer),&#xD;&#xA;globalMap&#xD;&#xA;);&#xD;&#xA;&#xD;&#xA;//==== ERGEBNISSE ZUWEISEN ====&#xD;&#xA;output_row.parsed_art                    = r.art;&#xD;&#xA;output_row.parsed_sorte                  = r.sorte;&#xD;&#xA;output_row.parsed_merkmale               = r.merkmale;&#xD;&#xA;output_row.parsed_schnittart             = r.schnittart;&#xD;&#xA;output_row.parsed_schnittgroesse         = r.schnittgroesse;&#xD;&#xA;output_row.parsed_farbe                  = r.farbe;&#xD;&#xA;output_row.parsed_land                   = r.land;&#xD;&#xA;output_row.parsed_bio                    = r.bio;&#xD;&#xA;output_row.parsed_siegel                 = r.siegel;&#xD;&#xA;output_row.parsed_mhd                    = r.mhd;&#xD;&#xA;output_row.parsed_zustand                = r.zustand;&#xD;&#xA;output_row.parsed_verband                = r.verband;&#xD;&#xA;output_row.parsed_prozent                = r.prozent;&#xD;&#xA;output_row.parsed_kaliber                = r.kaliber;&#xD;&#xA;output_row.parsed_gewicht                = r.gewicht;&#xD;&#xA;output_row.parsed_stueck                 = r.stueck;&#xD;&#xA;output_row.parsed_satz                   = r.satz;&#xD;&#xA;output_row.parsed_laenge                 = r.laenge;&#xD;&#xA;output_row.parsed_rest                   = r.rest;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="import java.util.Set;&#xA;import java.util.HashSet;&#xA;import java.util.Map;&#xA;import java.util.HashMap;&#xA;import routines.tmp_parser;"/>

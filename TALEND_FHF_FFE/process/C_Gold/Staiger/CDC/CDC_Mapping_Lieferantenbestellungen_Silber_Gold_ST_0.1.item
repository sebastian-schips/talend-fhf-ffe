    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_LieferBestellID = input_row.GR_LieferBestellID;&#xD;&#xA;output_row.GR_LieferantenID = input_row.GR_LieferantenID;&#xD;&#xA;output_row.GR_Betrieb = input_row.GR_Betrieb;&#xD;&#xA;output_row.LieferBestellID = input_row.LieferBestellID;&#xD;&#xA;output_row.LieferantID = input_row.LieferantID;&#xD;&#xA;output_row.Bestelldatum = input_row.Bestelldatum;&#xD;&#xA;output_row.Lieferdatum = input_row.Lieferdatum;&#xD;&#xA;output_row.GR_Lieferscheinnummer = input_row.GR_Lieferscheinnummer;&#xD;&#xA;output_row.Lieferscheinnummer = input_row.Lieferscheinnummer;&#xD;&#xA;output_row.GR_RechnungsID = input_row.GR_RechnungsID;&#xD;&#xA;output_row.Rechnungsnummer = input_row.Rechnungsnummer;&#xD;&#xA;output_row.Retoure = input_row.Retoure;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Update_change_id_list == null || context.Silver_Update_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Silver_Update_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Silver_Update_count = 0;&#xD;&#xA;}&#xD;&#xA; &#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA; &#xD;&#xA;if (context.Silver_Update_count == 0) {&#xD;&#xA;    context.Silver_Update_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Silver_Update_change_id_list = context.Silver_Update_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Silver_Update_count++;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>

    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//=============================================================================&#xD;&#xA;//tJava (Initialisierung) - Neue globalMap-Einträge für v0.2&#xD;&#xA;//FIX: Nur initialisieren wenn noch nicht vom Joblet befüllt!&#xD;&#xA;//=============================================================================&#xD;&#xA;&#xD;&#xA;//=== ART_SORTE_MAP ===&#xD;&#xA;if (globalMap.get(&quot;ART_SORTE_MAP&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;ART_SORTE_MAP&quot;, &#xD;&#xA; new java.util.HashMap&lt;String, java.util.List&lt;java.util.Map&lt;String,String>>>());&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=== FESTE_GROESSE_MAP ===&#xD;&#xA;if (globalMap.get(&quot;FESTE_GROESSE_MAP&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;FESTE_GROESSE_MAP&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=== SCHNITTART_1D_MAP / SCHNITTART_2D_MAP ===&#xD;&#xA;if (globalMap.get(&quot;SCHNITTART_1D_MAP&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;SCHNITTART_1D_MAP&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;if (globalMap.get(&quot;SCHNITTART_2D_MAP&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;SCHNITTART_2D_MAP&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=== KORREKTUR_SCHNITTART_LISTE ===&#xD;&#xA;if (globalMap.get(&quot;KORREKTUR_SCHNITTART_LISTE&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;KORREKTUR_SCHNITTART_LISTE&quot;, &#xD;&#xA; new java.util.ArrayList&lt;java.util.Map&lt;String,String>>());&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=== MANUELLE KORREKTUREN ===&#xD;&#xA;if (globalMap.get(&quot;MANUELL_ART&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;MANUELL_ART&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;if (globalMap.get(&quot;MANUELL_SORTE&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;MANUELL_SORTE&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;if (globalMap.get(&quot;MANUELL_SCHNITTART&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;MANUELL_SCHNITTART&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;if (globalMap.get(&quot;MANUELL_SCHNITTGROESSE&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;MANUELL_SCHNITTGROESSE&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=== SIEGEL ===&#xD;&#xA;if (globalMap.get(&quot;SIEGEL&quot;) == null) {&#xD;&#xA;globalMap.put(&quot;SIEGEL&quot;, new java.util.HashMap&lt;String,String>());&#xD;&#xA;}"/>

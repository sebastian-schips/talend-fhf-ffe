  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="880" posY="-40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_6" show="false"/>
    <elementParameter field="CHECK" name="ACTIVATE" value="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_BestellID = input_row.GR_BestellID;&#xD;&#xA;output_row.GR_PositionsID = input_row.GR_PositionsID;&#xD;&#xA;output_row.PositionsID = input_row.PositionsID;&#xD;&#xA;output_row.GR_Betrieb = input_row.GR_Betrieb;&#xD;&#xA;output_row.Bestellnummer = input_row.Bestellnummer;&#xD;&#xA;output_row.Artikelnummer = input_row.Artikelnummer;&#xD;&#xA;output_row.Artikelbezeichnung = input_row.Artikelbezeichnung;&#xD;&#xA;output_row.Menge = input_row.Menge;&#xD;&#xA;output_row.Kolli = input_row.Kolli;&#xD;&#xA;output_row.Inhalt = input_row.Inhalt;&#xD;&#xA;output_row.Gewicht = input_row.Gewicht;&#xD;&#xA;output_row.Preis = input_row.Preis;&#xD;&#xA;output_row.Bestelleinheit = input_row.Bestelleinheit;&#xD;&#xA;output_row.PreisSummePosition = input_row.PreisSummePosition;&#xD;&#xA;output_row.Preiseinheit = input_row.Preiseinheit;&#xD;&#xA;output_row.Rabatt = input_row.Rabatt;&#xD;&#xA;output_row.GewichtSummePosition = input_row.GewichtSummePosition;&#xD;&#xA;output_row.Warenwert_netto = input_row.Warenwert_netto;&#xD;&#xA;output_row.Warenwert_brutto = input_row.Warenwert_brutto;&#xD;&#xA;output_row.Steuersatz = input_row.Steuersatz;&#xD;&#xA;output_row.Lieferdatum_Position = input_row.Lieferdatum_Position;&#xD;&#xA;output_row.Bemerkung = input_row.Bemerkung;&#xD;&#xA;output_row.Sortierung = input_row.Sortierung;&#xD;&#xA;output_row.EK_Preis = input_row.EK_Preis;&#xD;&#xA;output_row.EK_Preiseinheit = input_row.EK_Preiseinheit;&#xD;&#xA;output_row.EK_PreisSummePosition = input_row.EK_PreisSummePosition;&#xD;&#xA;output_row.Marge = input_row.Marge;&#xD;&#xA;output_row.MargeSummePosition = input_row.MargeSummePosition;&#xD;&#xA;output_row.Leergut = input_row.Leergut;&#xD;&#xA;output_row.Letzte_Aenderung = input_row.Letzte_Aenderung;&#xD;&#xA;output_row.Erstellt_Am = input_row.Erstellt_Am;&#xD;&#xA;output_row.Gruppe = input_row.Gruppe;&#xD;&#xA;output_row.Artikelfamilie = input_row.Artikelfamilie;&#xD;&#xA;output_row.Unterwarengruppe = input_row.Unterwarengruppe;&#xD;&#xA;output_row.Hauptwarengruppe = input_row.Hauptwarengruppe;&#xD;&#xA;output_row.Rechnungsnummer = input_row.Rechnungsnummer;&#xD;&#xA;output_row.Rechnungsdatum = input_row.Rechnungsdatum;&#xD;&#xA;&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;&#xD;&#xA;//Alle parsed-Felder standardmäßig auf NULL&#xD;&#xA;output_row.parsed_art = null;&#xD;&#xA;output_row.parsed_sorte = null;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//Bedingung: Nur ausführen, wenn Unterwarengruppe &quot;Obst &amp; Gemüse&quot;&#xD;&#xA;if (&quot;Obst (Rohware)&quot;.equals(input_row.Unterwarengruppe) || &quot;Gemüse (Rohware)&quot;.equals(input_row.Unterwarengruppe)) {&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//=== NORMALISIERUNG UND VORBEREITUNG ===&#xD;&#xA;&#x9;String inhalt = tmp_parser.normalize(input_row.Artikelbezeichnung);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//Ersetzungen (gecacht)&#xD;&#xA;&#x9;inhalt = tmp_parser.wordToAlternativeCached(&quot;PLURAL&quot;,   (java.util.Map&lt;String,String>)globalMap.get(&quot;PLURAL&quot;),    inhalt);&#xD;&#xA;&#x9;inhalt = tmp_parser.wordToAlternativeCached(&quot;KORREKTUR&quot;,(java.util.Map&lt;String,String>)globalMap.get(&quot;KORREKTUR&quot;),  inhalt);&#xD;&#xA;&#x9;inhalt = tmp_parser.wordToAlternativeCached(&quot;PLURAL&quot;,   (java.util.Map&lt;String,String>)globalMap.get(&quot;PLURAL&quot;),    inhalt);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;String[] result;&#xD;&#xA;&#x9;String restText = inhalt;&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//1. ART&#xD;&#xA;&#x9;result = tmp_parser.extrahiereReferenz(restText, (java.util.Set&lt;String>)globalMap.get(&quot;ART&quot;));&#xD;&#xA;&#x9;output_row.parsed_art = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//2. SORTE&#xD;&#xA;&#x9;result = tmp_parser.extrahiereReferenz(restText, (java.util.Set&lt;String>)globalMap.get(&quot;SORT&quot;));&#xD;&#xA;&#x9;output_row.parsed_sorte = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//3. MERKMALE (cached)&#xD;&#xA;&#x9;result = tmp_parser.extrahiereMerkmaleCached(&quot;MERKMAL&quot;, restText, (java.util.Set&lt;String>)globalMap.get(&quot;MERKMAL&quot;));&#xD;&#xA;&#x9;output_row.parsed_merkmale = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//4. FARBEN&#xD;&#xA;&#x9;result = tmp_parser.extrahiereReferenz(restText, (java.util.Set&lt;String>)globalMap.get(&quot;FARBEN&quot;));&#xD;&#xA;&#x9;output_row.parsed_farbe = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restKeep(result, 1, restText);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//5. LAND (cached)&#xD;&#xA;&#x9;result = tmp_parser.extrahiereWordSynonymCached(&quot;LAND&quot;, restText, (java.util.HashMap&lt;String,String>)globalMap.get(&quot;LAND&quot;));&#xD;&#xA;&#x9;output_row.parsed_land = tmp_parser.nz(result[1]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 2);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//6. BIO (Pattern statt String-Konkatenation)&#xD;&#xA;&#x9;boolean hasBio = tmp_parser.BIO_SPACE.matcher(restText).find()&#xD;&#xA;&#x9;    || tmp_parser.BIO_DASH.matcher(restText).find()&#xD;&#xA;&#x9;    || tmp_parser.BW_PAREN.matcher(restText).find();&#xD;&#xA;&#x9;if(hasBio){&#xD;&#xA;&#x9;output_row.parsed_bio = true;&#xD;&#xA;&#x9;restText = tmp_parser.BIO_SPACE.matcher(restText).replaceAll(&quot; &quot;);&#xD;&#xA;&#x9;restText = tmp_parser.BIO_DASH.matcher(restText).replaceAll(&quot; &quot;);&#xD;&#xA;&#x9;restText = tmp_parser.BW_PAREN.matcher(restText).replaceAll(&quot; &quot;);&#xD;&#xA;&#x9;restText = restText.replaceAll(&quot;\\s+&quot;,&quot; &quot;).trim();&#xD;&#xA;&#x9;}else{&#xD;&#xA;&#x9;output_row.parsed_bio = false;&#xD;&#xA;&#x9;}&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//7. SIEGEL (Pattern)&#xD;&#xA;&#x9;output_row.parsed_siegel = &quot;&quot;;&#xD;&#xA;&#x9;java.util.regex.Matcher bwm = tmp_parser.BW_TOKEN.matcher(restText);&#xD;&#xA;&#x9;if(bwm.find() &amp;&amp; !restText.contains(&quot;BIO-PFANDKISTE&quot;)){&#xD;&#xA;&#x9;restText = bwm.replaceAll(&quot; &quot;).replaceAll(&quot;\\s+&quot;,&quot; &quot;).trim();&#xD;&#xA;&#x9;output_row.parsed_siegel = &quot;bw&quot;;&#xD;&#xA;&#x9;}else if(tmp_parser.QZBW.matcher(restText).find()){&#xD;&#xA;&#x9;restText = tmp_parser.QZBW.matcher(restText).replaceAll(&quot; &quot;).replaceAll(&quot;\\s+&quot;,&quot; &quot;).trim();&#xD;&#xA;&#x9;output_row.parsed_siegel = &quot;qzbw&quot;;&#xD;&#xA;&#x9;}&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//8. MHD&#xD;&#xA;&#x9;result = tmp_parser.extractMhdDate(restText);&#xD;&#xA;&#x9;output_row.parsed_mhd = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//9. ZUSTAND&#xD;&#xA;&#x9;result = tmp_parser.extrahiereReferenz(restText, (java.util.Set&lt;String>)globalMap.get(&quot;ZUSTAND&quot;));&#xD;&#xA;&#x9;output_row.parsed_zustand = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//10. VERBAND&#xD;&#xA;&#x9;result = tmp_parser.extrahiereReferenz(restText, (java.util.Set&lt;String>)globalMap.get(&quot;VERBAENDE&quot;));&#xD;&#xA;&#x9;output_row.parsed_verband = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restKeep(result, 1, restText);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//11. PROZENT&#xD;&#xA;&#x9;result = tmp_parser.extractFirstPercentage(restText);&#xD;&#xA;&#x9;output_row.parsed_prozent = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//12. KALIBER&#xD;&#xA;&#x9;result = tmp_parser.extractFirstSlashNumber(restText);&#xD;&#xA;&#x9;if(result[0]!=null &amp;&amp; !result[0].isEmpty()){&#xD;&#xA;&#x9;output_row.parsed_kaliber = result[0];&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;}else{&#xD;&#xA;&#x9;result = tmp_parser.extrahiereKaliber(restText);&#xD;&#xA;&#x9;output_row.parsed_kaliber = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;}&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//13. GEWICHT + STÜCK (aus Text entfernen)&#xD;&#xA;&#x9;result = tmp_parser.extractWeightAndPiecesWithRest(restText);&#xD;&#xA;&#x9;output_row.parsed_gewicht = result[1]!=null ? result[1]+&quot;x&quot;+result[0] : (result[0]!=null?result[0]:&quot;&quot;);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 2);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//14. STÜCK&#xD;&#xA;&#x9;result = tmp_parser.extractPieces(restText);&#xD;&#xA;&#x9;output_row.parsed_stueck = result[0]!=null ? result[0]+&quot; &quot;+result[1] : &quot;&quot;;&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 2);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//15. SATZ&#xD;&#xA;&#x9;result = tmp_parser.extractErNumbers(restText);&#xD;&#xA;&#x9;output_row.parsed_satz = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//16. LÄNGE&#xD;&#xA;&#x9;result = tmp_parser.extractLength(restText);&#xD;&#xA;&#x9;output_row.parsed_laenge = tmp_parser.nz(result[0]);&#xD;&#xA;&#x9;restText = tmp_parser.restEmpty(result, 1);&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;//17. Rest&#xD;&#xA;&#x9;output_row.parsed_rest = restText!=null ? restText.trim() : &quot;&quot;;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="import java.util.Set;&#xA;import java.util.HashSet;&#xA;import java.util.Map;&#xA;import java.util.HashMap;&#xA;import routines.tmp_parser;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>

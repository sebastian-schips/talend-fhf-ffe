    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_BestellID = input_row.GR_BestellID;&#xD;&#xA;output_row.GR_PositionsID = input_row.GR_PositionsID;&#xD;&#xA;output_row.PositionsID = input_row.PositionsID;&#xD;&#xA;output_row.GR_Betrieb = input_row.GR_Betrieb;&#xD;&#xA;output_row.Bestellnummer = input_row.Bestellnummer;&#xD;&#xA;output_row.Artikelnummer = input_row.Artikelnummer;&#xD;&#xA;output_row.Artikelbezeichnung = input_row.Artikelbezeichnung;&#xD;&#xA;output_row.Menge = input_row.Menge;&#xD;&#xA;output_row.Kolli = input_row.Kolli;&#xD;&#xA;output_row.Inhalt = input_row.Inhalt;&#xD;&#xA;output_row.Gewicht = input_row.Gewicht;&#xD;&#xA;output_row.Preis = input_row.Preis;&#xD;&#xA;output_row.Bestelleinheit = input_row.Bestelleinheit;&#xD;&#xA;output_row.PreisSummePosition = input_row.PreisSummePosition;&#xD;&#xA;output_row.Preiseinheit = input_row.Preiseinheit;&#xD;&#xA;output_row.Rabatt = input_row.Rabatt;&#xD;&#xA;output_row.GewichtSummePosition = input_row.GewichtSummePosition;&#xD;&#xA;output_row.Warenwert_netto = input_row.Warenwert_netto;&#xD;&#xA;output_row.Warenwert_brutto = input_row.Warenwert_brutto;&#xD;&#xA;output_row.Steuersatz = input_row.Steuersatz;&#xD;&#xA;output_row.Lieferdatum_Position = input_row.Lieferdatum_Position;&#xD;&#xA;output_row.Bemerkung = input_row.Bemerkung;&#xD;&#xA;output_row.Sortierung = input_row.Sortierung;&#xD;&#xA;output_row.EK_Preis = input_row.EK_Preis;&#xD;&#xA;output_row.EK_Preiseinheit = input_row.EK_Preiseinheit;&#xD;&#xA;output_row.EK_PreisSummePosition = input_row.EK_PreisSummePosition;&#xD;&#xA;output_row.Marge = input_row.Marge;&#xD;&#xA;output_row.MargeSummePosition = input_row.MargeSummePosition;&#xD;&#xA;output_row.Leergut = input_row.Leergut;&#xD;&#xA;output_row.Letzte_Aenderung = input_row.Letzte_Aenderung;&#xD;&#xA;output_row.Erstellt_Am = input_row.Erstellt_Am;&#xD;&#xA;output_row.Gruppe = input_row.Gruppe;&#xD;&#xA;output_row.Artikelfamilie = input_row.Artikelfamilie;&#xD;&#xA;output_row.Unterwarengruppe = input_row.Unterwarengruppe;&#xD;&#xA;output_row.Hauptwarengruppe = input_row.Hauptwarengruppe;&#xD;&#xA;output_row.Rechnungsnummer = input_row.Rechnungsnummer;&#xD;&#xA;output_row.Rechnungsdatum = input_row.Rechnungsdatum;&#xD;&#xA;output_row.Land = input_row.Land;&#xD;&#xA;&#xD;&#xA;&#x9;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//=== ALLE PARSED-FELDER STANDARDMÄSSIG AUF LEER ===&#xD;&#xA;output_row.parsed_art = null;&#xD;&#xA;output_row.parsed_sorte = null;&#xD;&#xA;output_row.parsed_merkmale = null;&#xD;&#xA;output_row.parsed_schnittart = null;&#xD;&#xA;output_row.parsed_schnittgroesse = null;&#xD;&#xA;output_row.parsed_farbe = null;&#xD;&#xA;output_row.parsed_land = null;&#xD;&#xA;output_row.parsed_bio = false;&#xD;&#xA;output_row.parsed_siegel = &quot;&quot;;&#xD;&#xA;output_row.parsed_mhd = &quot;&quot;;&#xD;&#xA;output_row.parsed_zustand = &quot;&quot;;&#xD;&#xA;output_row.parsed_verband = &quot;&quot;;&#xD;&#xA;output_row.parsed_prozent = &quot;&quot;;&#xD;&#xA;output_row.parsed_kaliber = &quot;&quot;;&#xD;&#xA;output_row.parsed_gewicht = &quot;&quot;;&#xD;&#xA;output_row.parsed_stueck = &quot;&quot;;&#xD;&#xA;output_row.parsed_satz = &quot;&quot;;&#xD;&#xA;output_row.parsed_laenge = &quot;&quot;;&#xD;&#xA;output_row.parsed_rest = &quot;&quot;;&#xD;&#xA;&#xD;&#xA;//=== KATEGORIE BESTIMMEN ===&#xD;&#xA;int _kategorie = 0;&#xD;&#xA;if (&quot;Obst (Rohware)&quot;.equals(input_row.Unterwarengruppe)&#xD;&#xA;|| &quot;Gemüse (Rohware)&quot;.equals(input_row.Unterwarengruppe)) {&#xD;&#xA;_kategorie = 1;&#xD;&#xA;} else if (&quot;Obst (Schnittware)&quot;.equals(input_row.Unterwarengruppe)&#xD;&#xA;|| &quot;Gemüse (Schnittware)&quot;.equals(input_row.Unterwarengruppe)) {&#xD;&#xA;_kategorie = 2;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//===================================================================&#xD;&#xA;//Referenz-Listen aus globalMap holen (vom Joblet jb_referenzen)&#xD;&#xA;//ALLE Maps/Sets werden VOR dem if(_kategorie>0) geholt,&#xD;&#xA;//damit universelle Schritte (LAND, BIO, SIEGEL, MHD, VERBAND)&#xD;&#xA;//auch bei _kategorie==0 Zugriff haben.&#xD;&#xA;//===================================================================&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _mapKorrektur = (java.util.Map&lt;String,String>) globalMap.get(&quot;KORREKTUR&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _mapPlural = (java.util.Map&lt;String,String>) globalMap.get(&quot;PLURAL&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setArt = (java.util.Set&lt;String>) globalMap.get(&quot;ART&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setSort = (java.util.Set&lt;String>) globalMap.get(&quot;SORTE&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setMerkmal = (java.util.Set&lt;String>) globalMap.get(&quot;MERKMAL&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setSchnittart = (java.util.Set&lt;String>) globalMap.get(&quot;SCHNITTART&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setFarben = (java.util.Set&lt;String>) globalMap.get(&quot;FARBEN&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.HashMap&lt;String,String> _mapLand = (java.util.HashMap&lt;String,String>) globalMap.get(&quot;LAND&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setZustand = (java.util.Set&lt;String>) globalMap.get(&quot;ZUSTAND&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Set&lt;String> _setVerbaende = (java.util.Set&lt;String>) globalMap.get(&quot;VERBAENDE&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _mapSiegel = (java.util.Map&lt;String,String>) globalMap.get(&quot;SIEGEL&quot;);&#xD;&#xA;&#xD;&#xA;//===================================================================&#xD;&#xA;//Neue Maps für v0.2 (vom tJava_1 in globalMap gelegt)&#xD;&#xA;//WICHTIG: _ Prefix um Duplicate mit tJava_1 zu vermeiden!&#xD;&#xA;//===================================================================&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String, java.util.List&lt;java.util.Map&lt;String,String>>> _artSorteMap =&#xD;&#xA;(java.util.Map&lt;String, java.util.List&lt;java.util.Map&lt;String,String>>>) globalMap.get(&quot;ART_SORTE_MAP&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _festeGroesseMap =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;FESTE_GROESSE_MAP&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _schnittart1dMap =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;SCHNITTART_1D_MAP&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _schnittart2dMap =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;SCHNITTART_2D_MAP&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.List&lt;java.util.Map&lt;String,String>> _korrekturSchnittartListe =&#xD;&#xA;(java.util.List&lt;java.util.Map&lt;String,String>>) globalMap.get(&quot;KORREKTUR_SCHNITTART_LISTE&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _manuellArt =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;MANUELL_ART&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _manuellSorte =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;MANUELL_SORTE&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _manuellSchnittart =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;MANUELL_SCHNITTART&quot;);&#xD;&#xA;@SuppressWarnings(&quot;unchecked&quot;)&#xD;&#xA;java.util.Map&lt;String,String> _manuellSchnittgroesse =&#xD;&#xA;(java.util.Map&lt;String,String>) globalMap.get(&quot;MANUELL_SCHNITTGROESSE&quot;);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 1: NORMALISIERUNG (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;String _inhalt = tmp_parser.normalize(input_row.Artikelbezeichnung);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 2: SCHREIBFEHLER-KORREKTUR (immer, vor Plural!)&#xD;&#xA;//=========================================================================&#xD;&#xA;_inhalt = tmp_parser.wordToAlternativeCached(&quot;KORREKTUR&quot;, _mapKorrektur, _inhalt);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 3: PLURAL → SINGULAR (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;_inhalt = tmp_parser.wordToAlternativeCached(&quot;PLURAL&quot;, _mapPlural, _inhalt);&#xD;&#xA;&#xD;&#xA;String[] _result;&#xD;&#xA;String _restText = _inhalt;&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 4..8: OG-spezifische Schritte (ART, SORTE, MERKMALE, SCHNITTART)&#xD;&#xA;//NUR bei Rohware (_kategorie==1) oder Schnittware (_kategorie==2)&#xD;&#xA;//=========================================================================&#xD;&#xA;if (_kategorie > 0) {&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 4: ART (mit Wortgrenzen, Mehrwort-fähig)&#xD;&#xA;//→ Fallback: Artikelfamilie durchsuchen wenn keine Art gefunden&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereArtMitWortgrenzen(_restText, _setArt);&#xD;&#xA;String _gefundeneArt = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//FALLBACK: Wenn keine Art in Bezeichnung1 → Artikelfamilie durchsuchen&#xD;&#xA;String _artAusArtikelfamilie = &quot;&quot;;&#xD;&#xA;if (_gefundeneArt.isEmpty() &amp;&amp; input_row.Artikelfamilie != null&#xD;&#xA;&amp;&amp; !input_row.Artikelfamilie.trim().isEmpty()) {&#xD;&#xA;String _famNorm = tmp_parser.normalize(input_row.Artikelfamilie);&#xD;&#xA;_famNorm = tmp_parser.wordToAlternativeCached(&quot;KORREKTUR&quot;, _mapKorrektur, _famNorm);&#xD;&#xA;_famNorm = tmp_parser.wordToAlternativeCached(&quot;PLURAL&quot;, _mapPlural, _famNorm);&#xD;&#xA;String[] _famResult = tmp_parser.extrahiereArtMitWortgrenzen(_famNorm, _setArt);&#xD;&#xA;_artAusArtikelfamilie = tmp_parser.nz(_famResult[0]);&#xD;&#xA;if (!_artAusArtikelfamilie.isEmpty()) {&#xD;&#xA;_gefundeneArt = _artAusArtikelfamilie;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 5: SORTE (kontextabhängig zur Art)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereSorteKontextabhaengig(&#xD;&#xA;_restText, _gefundeneArt, _artSorteMap);&#xD;&#xA;String _gefundeneSorte = tmp_parser.nz(_result[0]);&#xD;&#xA;String _artAusSorte = (_result.length > 2) ? tmp_parser.nz(_result[2]) : &quot;&quot;;&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//Wenn Art leer aber über eindeutige Sorte ermittelt → übernehmen&#xD;&#xA;if (_gefundeneArt.isEmpty() &amp;&amp; !_artAusSorte.isEmpty()) {&#xD;&#xA;_gefundeneArt = _artAusSorte;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Fallback: Standard-Sorte wenn keine Sorte gefunden&#xD;&#xA;if (_gefundeneSorte.isEmpty() &amp;&amp; !_gefundeneArt.isEmpty() &amp;&amp; _artSorteMap != null) {&#xD;&#xA;String _stdSorte = tmp_parser.getStandardSorte(_gefundeneArt, _artSorteMap);&#xD;&#xA;if (_stdSorte != null &amp;&amp; !_stdSorte.isEmpty()) {&#xD;&#xA;_gefundeneSorte = _stdSorte;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;output_row.parsed_art = _gefundeneArt.isEmpty() ? null : _gefundeneArt;&#xD;&#xA;output_row.parsed_sorte = _gefundeneSorte.isEmpty() ? null : _gefundeneSorte;&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 6: MERKMALE&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereMerkmaleCached(&quot;MERKMAL&quot;, _restText, _setMerkmal);&#xD;&#xA;output_row.parsed_merkmale = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 7+8: SCHNITTART + SCHNITTGRÖSSE (NUR bei Schnittware!)&#xD;&#xA;//=========================================================================&#xD;&#xA;if (_kategorie == 2) {&#xD;&#xA;//--- SCHNITTART ---&#xD;&#xA;String _inhaltFuerSchnitt = _restText;&#xD;&#xA;if (!_gefundeneArt.isEmpty() &amp;&amp; _korrekturSchnittartListe != null) {&#xD;&#xA;_inhaltFuerSchnitt = tmp_parser.korrigiereSchnittartNachArt(&#xD;&#xA;    _inhaltFuerSchnitt, _gefundeneArt, _korrekturSchnittartListe);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Schnittart extrahieren&#xD;&#xA;_result = tmp_parser.extrahiereSchnittartenCached(&#xD;&#xA;&quot;SCHNITTART&quot;, _inhaltFuerSchnitt, _setSchnittart);&#xD;&#xA;String _gefundeneSchnittart = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//--- SCHNITTGRÖSSE ---&#xD;&#xA;String _gefundeneSchnittgroesse = tmp_parser.extrahiereSchnittgroesse(_restText);&#xD;&#xA;if (!_gefundeneSchnittgroesse.isEmpty()) {&#xD;&#xA;_restText = tmp_parser.SCHNITTGROESSE_2D.matcher(_restText).replaceFirst(&quot; &quot;);&#xD;&#xA;_restText = tmp_parser.SCHNITTGROESSE_1D.matcher(_restText).replaceFirst(&quot; &quot;);&#xD;&#xA;_restText = _restText.replaceAll(&quot;\\s+&quot;, &quot; &quot;).trim();&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Feste Größe: Wenn Schnittart eine feste Größe hat und keine gefunden&#xD;&#xA;if (!_gefundeneSchnittart.isEmpty() &amp;&amp; _gefundeneSchnittgroesse.isEmpty()&#xD;&#xA;&amp;&amp; _festeGroesseMap != null) {&#xD;&#xA;String _feste = _festeGroesseMap.get(_gefundeneSchnittart.toLowerCase());&#xD;&#xA;if (_feste != null &amp;&amp; !_feste.isEmpty()) {&#xD;&#xA;    _gefundeneSchnittgroesse = _feste;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Würfel-Korrektur: 15mm → 15x15mm&#xD;&#xA;if (!_gefundeneSchnittgroesse.isEmpty()&#xD;&#xA;&amp;&amp; _gefundeneSchnittart.toLowerCase().contains(&quot;würfel&quot;)&#xD;&#xA;&amp;&amp; !_gefundeneSchnittgroesse.contains(&quot;x&quot;)&#xD;&#xA;&amp;&amp; !_gefundeneSchnittgroesse.contains(&quot;-&quot;)) {&#xD;&#xA;String _zahl = _gefundeneSchnittgroesse.replace(&quot;mm&quot;, &quot;&quot;).trim();&#xD;&#xA;_gefundeneSchnittgroesse = _zahl + &quot;x&quot; + _zahl + &quot;mm&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Standard-Schnittart wenn Größe vorhanden aber keine Schnittart&#xD;&#xA;if (_gefundeneSchnittart.isEmpty() &amp;&amp; !_gefundeneSchnittgroesse.isEmpty()&#xD;&#xA;&amp;&amp; !_gefundeneArt.isEmpty()) {&#xD;&#xA;if (_gefundeneSchnittgroesse.contains(&quot;x&quot;)) {&#xD;&#xA;    if (_schnittart2dMap != null) {&#xD;&#xA;        String _std2d = _schnittart2dMap.get(_gefundeneArt.toLowerCase());&#xD;&#xA;        if (_std2d != null) _gefundeneSchnittart = _std2d;&#xD;&#xA;    }&#xD;&#xA;} else {&#xD;&#xA;    if (_schnittart1dMap != null) {&#xD;&#xA;        String _std1d = _schnittart1dMap.get(_gefundeneArt.toLowerCase());&#xD;&#xA;        if (_std1d != null) _gefundeneSchnittart = _std1d;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;output_row.parsed_schnittart = _gefundeneSchnittart.isEmpty() ? null : _gefundeneSchnittart;&#xD;&#xA;output_row.parsed_schnittgroesse = _gefundeneSchnittgroesse.isEmpty() ? null : _gefundeneSchnittgroesse;&#xD;&#xA;&#xD;&#xA;} &#xD;&#xA;&#xD;&#xA;} // === ENDE if (_kategorie > 0) ===&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//AB HIER: UNIVERSELLE SCHRITTE – laufen IMMER (auch bei _kategorie==0)&#xD;&#xA;//=========================================================================&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 9: FARBE (mit Wortgrenzen)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereFarbeMitWortgrenzen(_restText, _setFarben);&#xD;&#xA;output_row.parsed_farbe = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restKeep(_result, 1, _restText);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 10: LAND (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereWordSynonymCached(&quot;LAND&quot;, _restText, _mapLand);&#xD;&#xA;output_row.parsed_land = tmp_parser.nz(_result[1]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 2);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 11: BIO (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;boolean _hasBio = tmp_parser.BIO_SPACE.matcher(_restText).find()&#xD;&#xA;|| tmp_parser.BIO_DASH.matcher(_restText).find();&#xD;&#xA;if (_hasBio) {&#xD;&#xA;output_row.parsed_bio = true;&#xD;&#xA;_restText = tmp_parser.BIO_SPACE.matcher(_restText).replaceAll(&quot; &quot;);&#xD;&#xA;_restText = tmp_parser.BIO_DASH.matcher(_restText).replaceAll(&quot; &quot;);&#xD;&#xA;_restText = _restText.replaceAll(&quot;\\s+&quot;, &quot; &quot;).trim();&#xD;&#xA;} else {&#xD;&#xA;output_row.parsed_bio = false;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 12: SIEGEL (immer, referenzdatenbasiert mit Fallback)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereSiegelCached(_restText, _mapSiegel);&#xD;&#xA;output_row.parsed_siegel = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 13: MHD (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extractMhdDate(_restText);&#xD;&#xA;output_row.parsed_mhd = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 14: ZUSTAND (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereReferenz(_restText, _setZustand);&#xD;&#xA;output_row.parsed_zustand = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 15: VERBAND (immer)&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extrahiereReferenz(_restText, _setVerbaende);&#xD;&#xA;output_row.parsed_verband = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restKeep(_result, 1, _restText);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 16: PROZENT&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extractFirstPercentage(_restText);&#xD;&#xA;output_row.parsed_prozent = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 17: KALIBER&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extractFirstSlashNumber(_restText);&#xD;&#xA;if (_result[0] != null &amp;&amp; !_result[0].isEmpty()) {&#xD;&#xA;output_row.parsed_kaliber = _result[0];&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;} else {&#xD;&#xA;_result = tmp_parser.extrahiereKaliber(_restText);&#xD;&#xA;output_row.parsed_kaliber = tmp_parser.nz(_result[0]);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 18: GEWICHT + STÜCK&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extractWeightAndPiecesWithRest(_restText);&#xD;&#xA;output_row.parsed_gewicht = _result[1] != null&#xD;&#xA;? _result[1] + &quot;x&quot; + _result[0]&#xD;&#xA;: (_result[0] != null ? _result[0] : &quot;&quot;);&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 2);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 19: STÜCK&#xD;&#xA;//=========================================================================&#xD;&#xA;_result = tmp_parser.extractPieces(_restText);&#xD;&#xA;output_row.parsed_stueck = _result[0] != null&#xD;&#xA;? _result[0] + &quot; &quot; + _result[1] : &quot;&quot;;&#xD;&#xA;_restText = tmp_parser.restEmpty(_result, 2);&#xD;&#xA;&#xD;&#xA;//=========================================================================&#xD;&#xA;//SCHRITT 20: SATZ&#xD;&#xA;//=========================================================================&
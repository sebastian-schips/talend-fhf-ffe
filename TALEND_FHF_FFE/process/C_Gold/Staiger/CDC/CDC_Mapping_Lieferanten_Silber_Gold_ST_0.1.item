    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;output_row.Primary_Key_Value = input_row.Primary_Key_Value;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Delete_change_id_list == null || context.Silver_Delete_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Silver_Delete_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Silver_Delete_count = 0;&#xD;&#xA;}&#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA;if (context.Silver_Delete_count == 0) {&#xD;&#xA;    context.Silver_Delete_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Silver_Delete_change_id_list = context.Silver_Delete_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Silver_Delete_count++;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>

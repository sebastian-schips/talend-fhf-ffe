    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_BestellID = input_row.GR_BestellID;&#xD;&#xA;output_row.GR_KundenID = input_row.GR_KundenID;&#xD;&#xA;output_row.GR_ToutID = input_row.GR_ToutID;&#xD;&#xA;output_row.Bestellnummer = input_row.Bestellnummer;&#xD;&#xA;output_row.GR_Betrieb = input_row.GR_Betrieb;&#xD;&#xA;output_row.Kundennummer = input_row.Kundennummer;&#xD;&#xA;output_row.Bestelldatum = input_row.Bestelldatum;&#xD;&#xA;output_row.Lieferdatum = input_row.Lieferdatum;&#xD;&#xA;output_row.Lieferzeit_von = input_row.Lieferzeit_von;&#xD;&#xA;output_row.Lieferzeit_bis = input_row.Lieferzeit_bis;&#xD;&#xA;output_row.Tour = input_row.Tour;&#xD;&#xA;output_row.Station = input_row.Station;&#xD;&#xA;output_row.Bestellreferenz = input_row.Bestellreferenz;&#xD;&#xA;output_row.Rabatt = input_row.Rabatt;&#xD;&#xA;output_row.Auftrag_ohne_Berechnung = input_row.Auftrag_ohne_Berechnung;&#xD;&#xA;output_row.Lieferscheinnummer = input_row.Lieferscheinnummer;&#xD;&#xA;output_row.Kommentar = input_row.Kommentar;&#xD;&#xA;output_row.Letzte_Aenderung = input_row.Letzte_Aenderung;&#xD;&#xA;output_row.BestellungHerkunft = input_row.BestellungHerkunft;&#xD;&#xA;output_row.Change_ID = input_row.Change_ID;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (context.Silver_Update_change_id_list == null || context.Silver_Update_change_id_list.equals(&quot;&quot;)) {&#xD;&#xA;    context.Silver_Update_change_id_list = &quot;&quot;;&#xD;&#xA;    context.Silver_Update_count = 0;&#xD;&#xA;}&#xD;&#xA; &#xD;&#xA;String changeId = String.valueOf(input_row.Change_ID);&#xD;&#xA; &#xD;&#xA;if (context.Silver_Update_count == 0) {&#xD;&#xA;    context.Silver_Update_change_id_list = changeId;&#xD;&#xA;} else {&#xD;&#xA;    context.Silver_Update_change_id_list = context.Silver_Update_change_id_list + &quot;,&quot; + changeId;&#xD;&#xA;}&#xD;&#xA;context.Silver_Update_count++;"/>

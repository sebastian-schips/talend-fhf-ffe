    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;MERGE INTO \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;&quot; + context.DB_Ziel + &quot;\&quot; tgt &quot; +&#xD;&#xA;&quot;USING ( &quot; +&#xD;&#xA;&quot;   SELECT &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;GR_BestellID\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;GR_KundenID\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Bestellnummer\&quot; AS VARCHAR(255)) AS \&quot;Bestellnummer\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;GR_Betrieb\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Kundennummer\&quot; AS BIGINT) AS \&quot;Kundennummer\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATE, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Bestelldatum\&quot;, 120) AS \&quot;Bestelldatum\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATE, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Lieferdatum\&quot;, 120) AS \&quot;Lieferdatum\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Lieferzeit_von\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Lieferzeit_bis\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Tour\&quot; AS INT) AS \&quot;Tour\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Station\&quot; AS INT) AS \&quot;Station\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Bestellreferenz\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Rabatt\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Auftrag_ohne_Berechnung\&quot; AS INT) AS \&quot;Auftrag_ohne_Berechnung\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CAST(\&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Lieferscheinnummer\&quot; AS INT) AS \&quot;Lieferscheinnummer\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Kommentar\&quot;, &quot; +&#xD;&#xA;&quot;       TRY_CONVERT(DATE, \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;Letzte_Aenderung\&quot;, 120) AS \&quot;Letzte_Aenderung\&quot;, &quot; +&#xD;&#xA;&quot;       \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot;.\&quot;BestellungHerkunft\&quot; &quot; +&#xD;&#xA;&quot;   FROM \&quot;&quot; + context.GR_Master_Schema + &quot;\&quot;.\&quot;Staging_Gold_Update_&quot; + context.Kuerzel_Staging + &quot;_Kundenbestellung\&quot; &quot; +&#xD;&#xA;&quot;   WHERE \&quot;GR_BestellID\&quot; IS NOT NULL &quot; +&#xD;&#xA;&quot;     AND \&quot;GR_BestellID\&quot; &lt;> '' &quot; +&#xD;&#xA;&quot;) src &quot; +&#xD;&#xA;&quot;ON tgt.\&quot;GR_BestellID\&quot; = src.\&quot;GR_BestellID\&quot; &quot; +&#xD;&#xA;&quot;WHEN MATCHED THEN UPDATE SET &quot; +&#xD;&#xA;&quot;   tgt.\&quot;GR_KundenID\&quot; = src.\&quot;GR_KundenID\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Bestellnummer\&quot; = src.\&quot;Bestellnummer\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;GR_Betrieb\&quot; = src.\&quot;GR_Betrieb\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Kundennummer\&quot; = src.\&quot;Kundennummer\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Bestelldatum\&quot; = src.\&quot;Bestelldatum\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Lieferdatum\&quot; = src.\&quot;Lieferdatum\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Lieferzeit_von\&quot; = src.\&quot;Lieferzeit_von\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Lieferzeit_bis\&quot; = src.\&quot;Lieferzeit_bis\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Tour\&quot; = src.\&quot;Tour\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Station\&quot; = src.\&quot;Station\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Bestellreferenz\&quot; = src.\&quot;Bestellreferenz\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Rabatt\&quot; = src.\&quot;Rabatt\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Auftrag_ohne_Berechnung\&quot; = src.\&quot;Auftrag_ohne_Berechnung\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Lieferscheinnummer\&quot; = src.\&quot;Lieferscheinnummer\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Kommentar\&quot; = src.\&quot;Kommentar\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;Letzte_Aenderung\&quot; = src.\&quot;Letzte_Aenderung\&quot;, &quot; +&#xD;&#xA;&quot;   tgt.\&quot;BestellungHerkunft\&quot; = src.\&quot;BestellungHerkunft\&quot;;&quot;&#xD;&#xA;"/>

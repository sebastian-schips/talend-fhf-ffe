  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="480" posY="240">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//=============================================================================&#xD;&#xA;//tJavaRow Script v0.4 - Parsing mit Drei-Wege-Logik&#xD;&#xA;//Rohware / Schnittware / Convenience&#xD;&#xA;//SCHRITT 12: SIEGEL jetzt referenzdatenbasiert über _mapSiegel&#xD;&#xA;//Fallback auf alte Regex-Logik wenn _mapSiegel null/leer&#xD;&#xA;//FIX: Duplicate local variable - Variablen umbenannt mit _ Prefix&#xD;&#xA;//um Konflikte mit tJava_1 (gleicher Scope) zu vermeiden&#xD;&#xA;//=============================================================================&#xD;&#xA;&#xD;&#xA;//Code erstellt anhand des Eingabe- und Ausgabeschemas&#xD;&#xA;output_row.GR_BestellID = input_row.GR_BestellID;&#xD;&#xA;output_row.GR_PositionsID = input_row.GR_PositionsID;&#xD;&#xA;output_row.PositionsID = input_row.PositionsID;&#xD;&#xA;output_row.GR_Betrieb = input_row.GR_Betrieb;&#xD;&#xA;output_row.Bestellnummer = input_row.Bestellnummer;&#xD;&#xA;output_row.Artikelnummer = input_row.Artikelnummer;&#xD;&#xA;output_row.Artikelbezeichnung = input_row.Artikelbezeichnung;&#xD;&#xA;output_row.Menge = input_row.Menge;&#xD;&#xA;output_row.Kolli = input_row.Kolli;&#xD;&#xA;output_row.Inhalt = input_row.Inhalt;&#xD;&#xA;output_row.Gewicht = input_row.Gewicht;&#xD;&#xA;output_row.Preis = input_row.Preis;&#xD;&#xA;output_row.Bestelleinheit = input_row.Bestelleinheit;&#xD;&#xA;output_row.PreisSummePosition = input_row.PreisSummePosition;&#xD;&#xA;output_row.Preiseinheit = input_row.Preiseinheit;&#xD;&#xA;output_row.Rabatt = input_row.Rabatt;&#xD;&#xA;output_row.GewichtSummePosition = input_row.GewichtSummePosition;&#xD;&#xA;output_row.Warenwert_netto = input_row.Warenwert_netto;&#xD;&#xA;output_row.Warenwert_brutto = input_row.Warenwert_brutto;&#xD;&#xA;output_row.Steuersatz = input_row.Steuersatz;&#xD;&#xA;output_row.Lieferdatum_Position = input_row.Lieferdatum_Position;&#xD;&#xA;output_row.Bemerkung = input_row.Bemerkung;&#xD;&#xA;output_row.Sortierung = input_row.Sortierung;&#xD;&#xA;output_row.EK_Preis = input_row.EK_Preis;&#xD;&#xA;output_row.EK_Preiseinheit = input_row.EK_Preiseinheit;&#xD;&#xA;output_row.EK_PreisSummePosition = input_row.EK_PreisSummePosition;&#xD;&#xA;output_row.Marge = input_row.Marge;&#xD;&#xA;output_row.MargeSummePosition = input_row.MargeSummePosition;&#xD;&#xA;output_row.Leergut = input_row.Leergut;&#xD;&#xA;output_row.Letzte_Aenderung = input_row.Letzte_Aenderung;&#xD;&#xA;output_row.Erstellt_Am = input_row.Erstellt_Am;&#xD;&#xA;output_row.Gruppe = input_row.Gruppe;&#xD;&#xA;output_row.Artikelfamilie = input_row.Artikelfamilie;&#xD;&#xA;output_row.Unterwarengruppe = input_row.Unterwarengruppe;&#xD;&#xA;output_row.Hauptwarengruppe = input_row.Hauptwarengruppe;&#xD;&#xA;output_row.Rechnungsnummer = input_row.Rechnungsnummer;&#xD;&#xA;output_row.Rechnungsdatum = input_row.Rechnungsdatum;&#xD;&#xA;output_row.Land = input_row.Land;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//==== PARSING ====&#xD;&#xA;ArtikelParser.ArtikelParseResult r = ArtikelParser.parse(&#xD;&#xA;input_row.Artikelbezeichnung,&#xD;&#xA;input_row.Unterwarengruppe,&#xD;&#xA;input_row.Artikelfamilie,&#xD;&#xA;input_row.GR_Betrieb,&#xD;&#xA;String.valueOf(input_row.Artikelnummer),&#xD;&#xA;globalMap&#xD;&#xA;);&#xD;&#xA;&#xD;&#xA;//==== ERGEBNISSE ZUWEISEN ====&#xD;&#xA;output_row.parsed_art                    = r.art;&#xD;&#xA;output_row.parsed_sorte                  = r.sorte;&#xD;&#xA;output_row.parsed_merkmale               = r.merkmale;&#xD;&#xA;output_row.parsed_schnittart             = r.schnittart;&#xD;&#xA;output_row.parsed_schnittgroesse         = r.schnittgroesse;&#xD;&#xA;output_row.parsed_farbe                  = r.farbe;&#xD;&#xA;output_row.parsed_land                   = r.land;&#xD;&#xA;output_row.parsed_bio                    = r.bio;&#xD;&#xA;output_row.parsed_siegel                 = r.siegel;&#xD;&#xA;output_row.parsed_mhd                    = r.mhd;&#xD;&#xA;output_row.parsed_zustand                = r.zustand;&#xD;&#xA;output_row.parsed_verband                = r.verband;&#xD;&#xA;output_row.parsed_prozent                = r.prozent;&#xD;&#xA;output_row.parsed_kaliber                = r.kaliber;&#xD;&#xA;output_row.parsed_gewicht                = r.gewicht;&#xD;&#xA;output_row.parsed_stueck                 = r.stueck;&#xD;&#xA;output_row.parsed_satz                   = r.satz;&#xD;&#xA;output_row.parsed_laenge                 = r.laenge;&#xD;&#xA;output_row.parsed_rest                   = r.rest;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="import java.util.Set;&#xA;import java.util.HashSet;&#xA;import java.util.Map;&#xA;import java.util.HashMap;&#xA;import routines.tmp_parser;"/>

  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="560" posY="680">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;════════════════════════════════════════&quot;);&#xD;&#xA;System.out.println(&quot;Baue DELETE für &quot; + context.AuftragPosition_D_id_count + &quot; IDs&quot;);&#xD;&#xA;&#xD;&#xA;// DELETE SQL&#xD;&#xA;context.AuftragPosition_D_SQL = &#xD;&#xA;    &quot;DELETE FROM Staiger_AuftragPositionen WHERE Aup_Nummer IN (&quot; + context.AuftragPosition_D_where_clause + &quot;)&quot;;&#xD;&#xA;System.out.println(&quot;DELETE SQL: &quot; + context.AuftragPosition_D_SQL);&#xD;&#xA;&#xD;&#xA;// Timestamp&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;context.CDC_ProcessedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;// UPDATE SQL für CDC_Changes&#xD;&#xA;if (context.AuftragPosition_D_id_count > 0) {&#xD;&#xA;    context.CDC_Update_SQL = &#xD;&#xA;        &quot;UPDATE am.CDC_Changes &quot; +&#xD;&#xA;        &quot;SET Processed = 1, &quot; +&#xD;&#xA;        &quot;    Changed_At = '&quot; + context.CDC_ProcessedAt + &quot;' &quot; +&#xD;&#xA;        &quot;WHERE Change_ID IN (&quot; + context.AuftragPosition_D_change_id_in_clause + &quot;)&quot;;&#xD;&#xA;    System.out.println(&quot;CDC UPDATE SQL: &quot; + context.CDC_Update_SQL);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// -----------------------------------------------------&#xD;&#xA;// 3. SQL für CDC_Changes_Bronze - Korrigiert&#xD;&#xA;// -----------------------------------------------------&#xD;&#xA;String[] positionIds = context.AuftragPosition_D_where_clause.split(&quot;,&quot;);&#xD;&#xA;StringBuilder sqlBuilder = new StringBuilder();&#xD;&#xA;&#xD;&#xA;for (String id : positionIds) {&#xD;&#xA;    if (id != null &amp;&amp; !id.trim().isEmpty()) {&#xD;&#xA;        String pk = context.gr_kuerzel +  id.trim();&#xD;&#xA;        &#xD;&#xA;        sqlBuilder.append(&#xD;&#xA;            &quot;INSERT INTO dbo.CDC_Changes_Bronze &quot; +&#xD;&#xA;            &quot;(Table_Name, Operation_Type, Primary_Key_Value, Changed_At, Processed, Bronze_Processed_At) &quot; +&#xD;&#xA;            &quot;VALUES ('&quot; + context.table_name + &quot;', 'DELETE', '&quot; + pk + &#xD;&#xA;            &quot;', '&quot; + context.CDC_ProcessedAt + &quot;', 0, NULL);\n&quot;&#xD;&#xA;        );&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;context.CDC_Bronze_Delete_SQL = sqlBuilder.toString();&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;CDC Bronze DELETE SQL →&quot;);&#xD;&#xA;System.out.println(context.CDC_Bronze_Delete_SQL);&#xD;&#xA;System.out.println(&quot;════════════════════════════════════════&quot;);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>

id : artikelIds) {&#xD;&#xA; if (id != null &amp;&amp; !id.trim().isEmpty()) {&#xD;&#xA;     String pk = context.gr_kuerzel + id.trim();&#xD;&#xA;     &#xD;&#xA;     sqlBuilder.append(&#xD;&#xA;         &quot;INSERT INTO dbo.CDC_Changes_Bronze &quot; +&#xD;&#xA;         &quot;(Table_Name, Operation_Type, Primary_Key_Value, Changed_At, Processed, Bronze_Processed_At) &quot; +&#xD;&#xA;         &quot;VALUES ('&quot; + context.table_name + &quot;', 'INSERT', '&quot; + pk + &#xD;&#xA;         &quot;', '&quot; + context.CDC_ProcessedAt + &quot;', 0, NULL);\n&quot;&#xD;&#xA;     );&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;context.CDC_Bronze_Insert_SQL = sqlBuilder.toString();&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;CDC Bronze INSERT SQL →&quot;);&#xD;&#xA;System.out.println(context.CDC_Bronze_Insert_SQL);&#xD;&#xA;System.out.println(&quot;════════════════════════════════════════&quot;);"/>

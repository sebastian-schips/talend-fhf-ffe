    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;════════════════════════════════════════&quot;);&#xD;&#xA;System.out.println(&quot;Baue SELECT für &quot; + context.Lieferanten_I_id_count + &quot; IDs&quot;); &#xD;&#xA;&#xD;&#xA;context.Lieferanten_I_SQL =&#xD;&#xA;&quot;SELECT * FROM &quot; + context.table_name + &quot; WHERE &quot; + context.table_pk + &quot; IN (&quot; +context.Lieferanten_I_where_clause + &quot;)&quot;;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;SQL: &quot; + context.Lieferanten_I_SQL);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// -----------------------------------------------------&#xD;&#xA;// 1. Datum im Format dd.MM.yyyy HH:mm:ss erzeugen&#xD;&#xA;// -----------------------------------------------------&#xD;&#xA;java.text.SimpleDateFormat sdf =&#xD;&#xA;new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xD;&#xA;&#xD;&#xA;context.CDC_ProcessedAt = sdf.format(new java.util.Date());&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// -----------------------------------------------------&#xD;&#xA;// 2. UPDATE-SQL für die CDC-Tabelle erzeugen&#xD;&#xA;// -----------------------------------------------------&#xD;&#xA;if (context.Lieferanten_I_id_count > 0) {&#xD;&#xA;&#xD;&#xA;    context.CDC_Update_SQL =&#xD;&#xA;        &quot;UPDATE am.CDC_Changes &quot; +&#xD;&#xA;        &quot;SET Processed = 1, &quot; +&#xD;&#xA;        &quot;    Changed_At = '&quot; + context.CDC_ProcessedAt + &quot;' &quot; +&#xD;&#xA;        &quot;WHERE Change_ID IN (&quot; + context.Lieferanten_I_change_id_in_clause + &quot;)&quot;;&#xD;&#xA;&#xD;&#xA;    System.out.println(&quot;CDC UPDATE SQL → &quot; + context.CDC_Update_SQL);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//-----------------------------------------------------&#xD;&#xA;//3. SQL für CDC_Changes_Bronze - Lieferanten&#xD;&#xA;//-----------------------------------------------------&#xD;&#xA;String[] lieferantenIds = context.Lieferanten_I_where_clause.split(&quot;,&quot;);&#xD;&#xA;StringBuilder sqlBuilder = new StringBuilder();&#xD;&#xA;&#xD;&#xA;for (String id : lieferantenIds) {&#xD;&#xA; if (id != null &amp;&amp; !id.trim().isEmpty()) {&#xD;&#xA;     String pk = context.gr_kuerzel + id.trim();&#xD;&#xA;     &#xD;&#xA;     sqlBuilder.append(&#xD;&#xA;         &quot;INSERT INTO dbo.CDC_Changes_Bronze &quot; +&#xD;&#xA;         &quot;(Table_Name, Operation_Type, Primary_Key_Value, Changed_At, Processed, Bronze_Processed_At) &quot; +&#xD;&#xA;         &quot;VALUES ('&quot; + context.table_name + &quot;', 'INSERT', '&quot; + pk + &#xD;&#xA;         &quot;', '&quot; + context.CDC_ProcessedAt + &quot;', 0, NULL);\n&quot;&#xD;&#xA;     );&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;context.CDC_Bronze_Insert_SQL = sqlBuilder.toString();&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;CDC Bronze INSERT SQL →&quot;);&#xD;&#xA;System.out.println(context.CDC_Bronze_Insert_SQL);&#xD;&#xA;System.out.println(&quot;════════════════════════════════════════&quot;);"/>
